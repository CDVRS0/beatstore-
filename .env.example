# ── Database ────────────────────────────────────────────────
# Postgres connection string (Neon, Supabase, Railway, or your own)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="CDVRS"

# ── Auth (admin dashboard + customer accounts) ────────────────
# generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# ── Cloudflare R2 (S3-compatible storage) ──────────────────────
R2_ACCOUNT_ID="your-r2-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="cdvrs-beat-store"
# Public bucket URL (previews/artwork) — set up a public R2.dev domain or custom domain
NEXT_PUBLIC_CDN_HOSTNAME="your-public-r2-hostname"
NEXT_PUBLIC_CDN_URL="https://your-public-r2-hostname"

# ── Stripe ──────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# ── Email (Resend) ──────────────────────────────────────────
RESEND_API_KEY="re_your_resend_api_key"
EMAIL_FROM="CDVRS <orders@yourdomain.com>"

# ── Downloads ───────────────────────────────────────────────
# secret used to sign time-limited download tokens
DOWNLOAD_TOKEN_SECRET=""

# ── Analytics ───────────────────────────────────────────────
# Google Analytics 4 measurement ID, e.g. G-XXXXXXXXXX (leave blank to disable)
NEXT_PUBLIC_GA_ID=""

# ── Admin bootstrap (used only by prisma/seed.ts) ──────────
ADMIN_EMAIL="you@cdvrswrld.com"
ADMIN_PASSWORD="change-me-before-seeding"
